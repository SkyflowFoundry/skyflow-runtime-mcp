{
	"name": "skyflow-runtime-mcp",
	"version": "1.0.0",
	"description": "Skyflow Runtime MCP Server",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"dev": "./dev.sh",
		"build": "pnpm build:ui && pnpm build:server",
		"build:ui": "cd ui && (INPUT=dehydrate/mcp-app.html vite build & INPUT=rehydrate/mcp-app.html vite build & INPUT=dehydrate-file/mcp-app.html vite build & wait)",
		"build:server": "tsc",
		"start": "node dist/server.js",
		"server": "npx -y tsx src/server.ts",
		"inspector": "npx -y @modelcontextprotocol/inspector",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@modelcontextprotocol/ext-apps": "^1.3.1",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"dotenv": "^17.2.3",
		"express": "^5.1.0",
		"skyflow-node": "^2.0.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@types/express": "^5.0.3",
		"@types/node": "^24.10.1",
		"@vitest/coverage-v8": "^4.0.18",
		"typescript": "^5.9.3",
		"vite": "^8.0.2",
		"vite-plugin-singlefile": "^2.3.2",
		"vitest": "^4.0.8"
	}
}
